# =========================================
# .env
# =========================================

# Telegram API
API_ID=12345678
API_HASH=your_api_hash

# Bot Token
BOT_TOKEN=your_bot_token

# Assistant String Session
STRING_SESSION=your_string_session

# MongoDB
MONGO_DB_URL=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority

MONGO_DB_NAME=vc_music_bot

# Redis
REDIS_URL=redis://localhost:6379

# Spotify
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Bot Settings
DEFAULT_VOLUME=100
MAX_DURATION=3600
BITRATE=128
AUTO_LEAVE_TIME=300
LANGUAGE=en

# Sudo Users
SUDO_USERS=123456789

# Bot Info
BOT_NAME=Ultra Pro Music Bot
BOT_USERNAME=ultra_music_bot
ASSISTANT_NAME=Music Assistant

SUPPORT_GROUP=@YourSupportGroup
UPDATES_CHANNEL=@YourUpdatesChannel
